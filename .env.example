# Copy this file to .env and fill in real values.
# Never commit a real .env. The systemd unit reads from .env at startup.
# Permissions MUST be 600 (`chmod 600 .env`).

# --- Claude auth ---
# Pick ONE depending on config.py:JUDGE_BACKEND.
#
# (1) JUDGE_BACKEND="claude_cli" (default) — uses your subscription.
#     Get this by running `claude setup-token` from any logged-in machine.
#     Format: sk-ant-oat01-...
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
CLAUDE_CLI_PATH=/home/ubuntu/.local/bin/claude

# (2) JUDGE_BACKEND="anthropic_sdk" — uses API credits.
#     Get from https://console.anthropic.com/.   Format: sk-ant-api03-...
# ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Kalshi auth ---
# Dedicated key for paper_judge_bot. Do NOT reuse another bot's key; rate
# limits and risk should be isolated per bot.
KALSHI_KEY_ID=00000000-0000-0000-0000-000000000000
# Absolute path to RSA private-key PEM. Generate via Kalshi web UI then copy here.
KALSHI_PEM_PATH=/home/ubuntu/paper_judge_bot/kalshi_key.pem

# --- Discord notifications ---
# Webhook URL for the bot's status channel. Make a dedicated channel so this
# bot's chatter doesn't drown out the other bots'.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...
# Optional Discord user id to mention on alarms (e.g., daily-loss kill).
DISCORD_PING_USER_ID=

# --- Optional logging override ---
# DEBUG / INFO / WARNING / ERROR. Default INFO.
PAPER_JUDGE_BOT_LOG_LEVEL=INFO
