[Unit]
Description=Kalshi weather market price recorder (window-optimization data, Phase 1)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
ExecStart=/usr/bin/python3 /home/ubuntu/paper_judge_bot/tools/market_price_recorder.py
Restart=always
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
